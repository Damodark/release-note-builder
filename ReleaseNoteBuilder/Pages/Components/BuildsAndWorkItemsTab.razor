        {
            return "btn btn-large btn-selected";
        }
        return "btn btn-large btn-outline";
    }

    private void SelectBuildType(string buildType)
    {
        selectedBuildType = buildType;
        selectedProjectBuild = null;
        selectedConfigBuild = null;
        StateHasChanged();
    }

    private void SelectProjectBuild(BuildDto build)
    {
        selectedProjectBuild = build;
        StateHasChanged();
    }

    private void SelectConfigBuild(BuildDto build)
    {
        selectedConfigBuild = build;
        StateHasChanged();
    }

    private async Task SearchDefects()
    {
        isLoadingDefects = true;
        defectSearchPerformed = true;
        ErrorMessage = "";
        try
        {
            var allDefects = await WorkItemService.GetWorkItemsByTypeAsync("Bug");
            
            if (!allDefects.Any())
            {
                allDefects = GetSampleDefects();
            }

            searchedDefects = string.IsNullOrEmpty(defectSearchText)
                ? allDefects
                : allDefects.Where(d =>
                    d.Title.Contains(defectSearchText, StringComparison.OrdinalIgnoreCase) ||
                    d.AdoWorkItemId.Contains(defectSearchText, StringComparison.OrdinalIgnoreCase) ||
                    d.Description.Contains(defectSearchText, StringComparison.OrdinalIgnoreCase)
                ).ToList();
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to search defects: {ex.Message}";
            await ErrorMessageChanged.InvokeAsync(ErrorMessage);
            searchedDefects = GetSampleDefects();
        }
        finally
        {
            isLoadingDefects = false;
        }
    }

    private async Task SearchPBIs()
    {
        isLoadingPBIs = true;
        pbiSearchPerformed = true;
        ErrorMessage = "";
        try
        {
            var allPBIs = await WorkItemService.GetWorkItemsByTypeAsync("User Story");
            
            if (!allPBIs.Any())
            {
                allPBIs = GetSamplePBIs();
            }

            searchedPBIs = string.IsNullOrEmpty(pbiSearchText)
                ? allPBIs
                : allPBIs.Where(p =>
                    p.Title.Contains(pbiSearchText, StringComparison.OrdinalIgnoreCase) ||
                    p.AdoWorkItemId.Contains(pbiSearchText, StringComparison.OrdinalIgnoreCase) ||
                    p.Description.Contains(pbiSearchText, StringComparison.OrdinalIgnoreCase)
                ).ToList();
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to search PBIs: {ex.Message}";
            await ErrorMessageChanged.InvokeAsync(ErrorMessage);
            searchedPBIs = GetSamplePBIs();
        }
        finally
        {
            isLoadingPBIs = false;
        }
    }

    private void ClearDefectSearch()
    {
        defectSearchText = "";
        searchedDefects = GetSampleDefects();
        selectedDefects.Clear();
        UpdateSelectedWorkItems();
    }

    private void ClearPBISearch()
    {
        pbiSearchText = "";
        searchedPBIs = GetSamplePBIs();
        selectedPBIs.Clear();
        UpdateSelectedWorkItems();
    }

    private bool IsDefectSelected(WorkItemDto defect)
    {
        return selectedDefects.Any(x => x.Id == defect.Id);
    }

    private void ToggleDefect(WorkItemDto defect, bool isSelected)
    {
        if (isSelected)
        {
            if (!IsDefectSelected(defect))
                selectedDefects.Add(defect);
        }
        else
        {
            selectedDefects.RemoveAll(x => x.Id == defect.Id);
        }
        UpdateSelectedWorkItems();
    }

    private void RemoveDefect(WorkItemDto defect)
    {
        selectedDefects.RemoveAll(x => x.Id == defect.Id);
        UpdateSelectedWorkItems();
    }

    private void RemoveDefectFromList(WorkItemDto defect)
    {
        searchedDefects.Remove(defect);
        RemoveDefect(defect);
    }

    private bool IsPBISelected(WorkItemDto pbi)
    {
        return selectedPBIs.Any(x => x.Id == pbi.Id);
    }

    private void TogglePBI(WorkItemDto pbi, bool isSelected)
    {
        if (isSelected)
        {
            if (!IsPBISelected(pbi))
                selectedPBIs.Add(pbi);
        }
        else
        {
            selectedPBIs.RemoveAll(x => x.Id == pbi.Id);
        }
        UpdateSelectedWorkItems();
    }

    private void RemovePBI(WorkItemDto pbi)
    {
        selectedPBIs.RemoveAll(x => x.Id == pbi.Id);
        UpdateSelectedWorkItems();
    }

    private void RemovePBIFromList(WorkItemDto pbi)
    {
        searchedPBIs.Remove(pbi);
        RemovePBI(pbi);
    }

    private void UpdateSelectedWorkItems()
    {
        SelectedWorkItems.Clear();
        SelectedWorkItems.AddRange(selectedDefects);
        SelectedWorkItems.AddRange(selectedPBIs);
    }

    private async Task SaveAndGoToNotifications()
    {
        // Pass complete payload to next page
        var releaseData = new
        {
            ProjectName = ProjectName,
            Environment = "Production",
            ProjectBuild = selectedProjectBuild,
            ConfigBuild = selectedConfigBuild,
            SelectedDefects = selectedDefects,
            SelectedPBIs = selectedPBIs
        };

        // Store in session or pass via component parameters
        await SelectedWorkItemsChanged.InvokeAsync(selectedDefects.Concat(selectedPBIs).ToList());
        await OnComplete.InvokeAsync();
    }

    private async Task GoBack()
    {
        await OnBack.InvokeAsync();
    }
