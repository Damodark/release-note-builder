@using ReleaseNoteBuilder.Application.Interfaces
@using ReleaseNoteBuilder.Application.DTOs
@inject IBuildService BuildService
@inject IWorkItemService WorkItemService

<div class="tab-pane">
    <h3>Builds and Work Items</h3>

    <!-- Build Type Selection Section -->
    <div class="section">
        <h4>Step 1: Select Build Type</h4>
        <div class="build-type-buttons">
            <button @onclick="@(() => SelectBuildType("full"))" 
                    class="@GetBuildTypeClass("full")">
                Build + Config
            </button>
            <button @onclick="@(() => SelectBuildType("config"))" 
                    class="@GetBuildTypeClass("config")">
                Config Build Only
            </button>
        </div>
        @if (!string.IsNullOrEmpty(selectedBuildType))
        {
            <p class="mt-3 text-info">
                Selected: <strong>@(selectedBuildType == "full" ? "Build + Config" : "Config Build Only")</strong>
            </p>
        }
    </div>

    <!-- Build & Config Selection Section - Always Visible -->
    <div class="section">
        <h4>Step 2: Select Build and Config Versions</h4>
        
        @if (isLoadingBuilds)
        {
            <div class="alert alert-info">
                <p>Loading builds...</p>
            </div>
        }
        else if (!availableBuilds.Any())
        {
            <div class="alert alert-warning">
                <p>No builds available for project: <strong>@ProjectName</strong></p>
            </div>
        }
        else
        {
            <div class="versions-grid">
                <div class="version-column">
                    <h5>Project Build</h5>
                    <div class="version-list">
                        @foreach (var build in availableBuilds)
                        {
                            var isSelected = selectedProjectBuild?.Id == build.Id;
                            <label class="version-item @(isSelected ? "selected" : "")" 
                                   @onclick="@(() => SelectProjectBuild(build))">
                                <input type="radio" 
                                       name="projectBuild" 
                                       value="@build.Id"
                                       checked="@isSelected"
                                       @onchange="@((ChangeEventArgs e) => SelectProjectBuild(build))" 
                                       class="radio-input" />
                                <div class="build-info">
                                    <strong>Build #@build.Id</strong>
                                    <small class="version-badge">v@build.Version</small>
                                    <small>@build.Project - @build.Branch</small>
                                    <small class="status">@build.Status</small>
                                </div>
                            </label>
                        }
                    </div>
                </div>

                <div class="version-column">
                    <h5>Config Build</h5>
                    <div class="version-list">
                        @foreach (var build in availableBuilds)
                        {
                            var isSelected = selectedConfigBuild?.Id == build.Id;
                            <label class="version-item @(isSelected ? "selected" : "")" 
                                   @onclick="@(() => SelectConfigBuild(build))">
                                <input type="radio" 
                                       name="configBuild" 
                                       value="@build.Id"
                                       checked="@isSelected"
                                       @onchange="@((ChangeEventArgs e) => SelectConfigBuild(build))" 
                                       class="radio-input" />
                                <div class="build-info">
                                    <strong>Build #@build.Id</strong>
                                    <small class="version-badge">v@build.Version</small>
                                    <small>@build.Project - @build.Branch</small>
                                    <small class="status">@build.Status</small>
                                </div>
                            </label>
                        }
                    </div>
                </div>
            </div>

            @if (selectedProjectBuild != null && selectedConfigBuild != null)
            {
                <div class="alert alert-success mt-3">
                    <strong>Builds Selected:</strong> 
                    <br />Project Build #@selectedProjectBuild.Id (v@selectedProjectBuild.Version) - @selectedProjectBuild.Project
                    <br />Config Build #@selectedConfigBuild.Id (v@selectedConfigBuild.Version) - @selectedConfigBuild.Project
                </div>
            }
        }
    </div>

    <!-- Defects Section - Always Visible -->
    <div class="section">
        <h4>Step 3: Select Defects (Bugs)</h4>
        
        <div class="search-section">
            <div class="search-controls">
                <input @bind="defectSearchText" 
                       class="form-control" 
                       placeholder="Search by title, ID, or description..." />
                <button @onclick="SearchDefects" class="btn btn-primary">
                    Search
                </button>
                <button @onclick="ClearDefectSearch" class="btn btn-secondary">
                    Clear
                </button>
            </div>
        </div>

        @if (isLoadingDefects)
        {
            <p class="text-info">Searching defects...</p>
        }
        else
        {
            <div class="work-items-list">
                @if (searchedDefects.Any())
                {
                    @foreach (var defect in searchedDefects)
                    {
                        <div class="work-item-row-compact">
                            <div class="work-item-header">
                                <label class="checkbox-item-compact">
                                    <input type="checkbox" 
                                           class="checkbox-small"
                                           @onchange="@((ChangeEventArgs e) => ToggleDefect(defect, (bool)e.Value))"
                                           checked="@IsDefectSelected(defect)" />
                                    <span class="checkbox-label-compact">
                                        <strong>@defect.AdoWorkItemId</strong> - @defect.Title
                                    </span>
                                </label>
                            </div>
                            <div class="defect-details">
                                <small class="detail-badge">👤 @defect.Author</small>
                                <small class="priority-badge priority-@(defect.Priority?.ToLower() ?? "medium")">@defect.Priority</small>
                                <small class="status-badge">@defect.Status</small>
                            </div>
                            <button @onclick="@(() => RemoveDefectFromList(defect))" 
                                    class="btn-remove-item-compact" 
                                    title="Remove">
                                ✕
                            </button>
                        </div>
                    }
                }
                else if (!defectSearchPerformed)
                {
                    <p class="text-muted">Click "Search" to load defects or select from the list below</p>
                }
                else
                {
                    <p class="text-warning">No defects found matching your search</p>
                }
            </div>
            @if (searchedDefects.Any())
            {
                <div class="mt-2">
                    <strong>Available Defects: @searchedDefects.Count | Selected: @selectedDefects.Count</strong>
                </div>
            }
        }

        <!-- Selected Defects Display -->
        @if (selectedDefects.Any())
        {
            <div class="section mt-3">
                <h5>Selected Defects (@selectedDefects.Count)</h5>
                <div class="selected-items-list">
                    @foreach (var defect in selectedDefects)
                    {
                        <div class="selected-item">
                            <span class="item-id">ID: @defect.Id</span>
                            <span class="item-badge">🐛 @defect.AdoWorkItemId</span>
                            <span class="item-text">@defect.Title</span>
                            <button @onclick="@(() => RemoveDefect(defect))" class="btn-remove">✕</button>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <!-- PBI Section - Always Visible -->
    <div class="section">
        <h4>Step 4: Select PBIs / User Stories</h4>
        
        <div class="search-section">
            <div class="search-controls">
                <input @bind="pbiSearchText" 
                       class="form-control" 
                       placeholder="Search by title, ID, or description..." />
                <button @onclick="SearchPBIs" class="btn btn-primary">
                    Search
                </button>
                <button @onclick="ClearPBISearch" class="btn btn-secondary">
                    Clear
                </button>
            </div>
        </div>

        @if (isLoadingPBIs)
        {
            <p class="text-info">Searching PBIs...</p>
        }
        else
        {
            <div class="work-items-list">
                @if (searchedPBIs.Any())
                {
                    @foreach (var pbi in searchedPBIs)
                    {
                        <div class="work-item-row">
                            <div class="work-item-header">
                                <label class="checkbox-item">
                                    <input type="checkbox" 
                                           @onchange="@((ChangeEventArgs e) => TogglePBI(pbi, (bool)e.Value))"
                                           checked="@IsPBISelected(pbi)" />
                                    <span class="checkbox-label">
                                        <strong>@pbi.AdoWorkItemId</strong> - @pbi.Title
                                        <small>(@pbi.Description)</small>
                                    </span>
                                </label>
                            </div>
                            <button @onclick="@(() => RemovePBIFromList(pbi))" 
                                    class="btn-remove-item" 
                                    title="Remove from list">
                                ✕
                            </button>
                        </div>
                    }
                }
                else if (!pbiSearchPerformed)
                {
                    <p class="text-muted">Click "Search" to load PBIs or select from the list below</p>
                }
                else
                {
                    <p class="text-warning">No PBIs found matching your search</p>
                }
            </div>
            @if (searchedPBIs.Any())
            {
                <div class="mt-2">
                    <strong>Available PBIs: @searchedPBIs.Count | Selected: @selectedPBIs.Count</strong>
                </div>
            }
        }

        <!-- Selected PBIs Display -->
        @if (selectedPBIs.Any())
        {
            <div class="section mt-3">
                <h5>Selected PBIs / User Stories (@selectedPBIs.Count)</h5>
                <div class="selected-items-list">
                    @foreach (var pbi in selectedPBIs)
                    {
                        <div class="selected-item">
                            <span class="item-id">ID: @pbi.Id</span>
                            <span class="item-badge">📋 @pbi.AdoWorkItemId</span>
                            <span class="item-text">@pbi.Title</span>
                            <button @onclick="@(() => RemovePBI(pbi))" class="btn-remove">✕</button>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <!-- Form Actions -->
    <div class="section">
        <div class="form-actions">
            <button @onclick="GoBack" class="btn btn-secondary btn-lg">
                Back
            </button>
            <button @onclick="SaveAndGoToNotifications" 
                    class="btn btn-primary btn-lg" 
                    disabled="@(selectedProjectBuild == null || selectedConfigBuild == null)">
                Save and Next
            </button>
        </div>
    </div>

    <ReleaseDocumentDownload 
        ProjectName="@ProjectName"
        Environment="@ReleaseEnvironment"
        ProjectBuild="@selectedProjectBuild"
        ConfigBuild="@selectedConfigBuild"
        Bugs="@selectedDefects"
        PBIs="@selectedPBIs"
        RequestedBy="@CurrentUser"
        ApprovedBy="Release Management" />

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger mt-3">Error: @ErrorMessage</div>
    }
</div>

<style>
