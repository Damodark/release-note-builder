@code {
    [Parameter]
    public List<WorkItemDto> SelectedWorkItems { get; set; } = new();

    [Parameter]
    public EventCallback<List<WorkItemDto>> SelectedWorkItemsChanged { get; set; }

    [Parameter]
    public EventCallback OnComplete { get; set; }

    [Parameter]
    public EventCallback OnBack { get; set; }

    [Parameter]
    public string ProjectName { get; set; } = "";

    [Parameter]
    public int BuildId { get; set; } = 0;

    [Parameter]
    public string ErrorMessage { get; set; } = "";

    [Parameter]
    public EventCallback<string> ErrorMessageChanged { get; set; }

    [Parameter]
    public BuildDto SelectedProjectBuild { get; set; }

    [Parameter]
    public BuildDto SelectedConfigBuild { get; set; }

    [Parameter]
    public string ReleaseEnvironment { get; set; } = "Production";

    [Parameter]
    public string CurrentUser { get; set; } = "Admin User";

    private string selectedBuildType = "";
    private BuildDto selectedProjectBuild = null;
    private BuildDto selectedConfigBuild = null;
    private List<BuildDto> availableBuilds = new();

    private List<WorkItemDto> searchedDefects = new();
    private List<WorkItemDto> searchedPBIs = new();
    private List<WorkItemDto> selectedDefects = new();
    private List<WorkItemDto> selectedPBIs = new();

    private string defectSearchText = "";
    private string pbiSearchText = "";

    private bool defectSearchPerformed = false;
    private bool pbiSearchPerformed = false;
    private bool isLoadingBuilds = false;
    private bool isLoadingDefects = false;
    private bool isLoadingPBIs = false;

    protected override async Task OnInitializedAsync()
    {
        await FetchBuilds();
        await InitializeSampleData();
    }

    private async Task FetchBuilds()
    {
        isLoadingBuilds = true;
        ErrorMessage = "";
        try
        {
            if (!string.IsNullOrEmpty(ProjectName))
            {
                availableBuilds = await BuildService.GetBuildsByProjectAsync(ProjectName);
            }
            else
            {
                availableBuilds = await BuildService.GetAllBuildsAsync();
            }

            // If no builds from service, use sample data
            if (!availableBuilds.Any())
            {
                availableBuilds = GetSampleBuilds();
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to fetch builds: {ex.Message}";
            await ErrorMessageChanged.InvokeAsync(ErrorMessage);
            // Use sample data on error
            availableBuilds = GetSampleBuilds();
        }
        finally
        {
            isLoadingBuilds = false;
        }
    }

    private async Task InitializeSampleData()
    {
        try
        {
            var allDefects = await WorkItemService.GetWorkItemsByTypeAsync("Bug");
            if (!allDefects.Any())
            {
                searchedDefects = GetSampleDefects();
            }
            else
            {
                searchedDefects = allDefects;
            }

            var allPBIs = await WorkItemService.GetWorkItemsByTypeAsync("User Story");
            if (!allPBIs.Any())
            {
                searchedPBIs = GetSamplePBIs();
            }
            else
            {
                searchedPBIs = allPBIs;
            }

            defectSearchPerformed = true;
            pbiSearchPerformed = true;
        }
        catch
        {
            // Use sample data on error
            searchedDefects = GetSampleDefects();
            searchedPBIs = GetSamplePBIs();
            defectSearchPerformed = true;
            pbiSearchPerformed = true;
        }
    }

    private List<BuildDto> GetSampleBuilds()
    {
        return new List<BuildDto>
        {
            new BuildDto 
            { 
                Id = 1001, 
                Project = "MortgageMate - Au", 
                Version = "2.1.5",
                Branch = "main", 
                Status = "Success",
                CreatedDate = DateTime.Now.AddDays(-5)
            },
            new BuildDto 
            { 
                Id = 1002, 
                Project = "MortgageMate - Au", 
                Version = "2.1.4",
                Branch = "main", 
                Status = "Success",
                CreatedDate = DateTime.Now.AddDays(-3)
            },
            new BuildDto 
            { 
