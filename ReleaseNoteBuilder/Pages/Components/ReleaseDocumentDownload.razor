@using Microsoft.JSInterop
@using ReleaseNoteBuilder.Application.Interfaces
@using ReleaseNoteBuilder.Application.DTOs
@inject IReleaseDocumentService DocumentService
@inject IJSRuntime JSRuntime

<div class="document-download-section">
    <h4>Export Release Notes</h4>

    <div class="download-controls">
        <button @onclick="DownloadDocument" 
                class="btn btn-success btn-lg"
                disabled="@(!IsReadyForDownload)">
            📄 Download Word Document
        </button>
        @if (!IsReadyForDownload)
        {
            <small class="text-muted">Select builds and items to enable download</small>
        }
    </div>

    @if (!string.IsNullOrEmpty(StatusMessage))
    {
        <div class="alert @(IsError ? "alert-danger" : "alert-success") mt-3">
            @StatusMessage
        </div>
    }
</div>

<style>
    .document-download-section {
        padding: 20px;
        background: #f0f8ff;
        border: 1px solid #add8e6;
        border-radius: 8px;
        margin: 20px 0;
    }

    .document-download-section h4 {
        margin-top: 0;
        color: #0078d4;
    }

    .download-controls {
        display: flex;
        gap: 15px;
        align-items: center;
        flex-wrap: wrap;
    }

    .btn-success {
        background: #28a745;
        color: white;
        border: none;
        padding: 12px 24px;
        border-radius: 4px;
        font-size: 16px;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-success:hover:not(:disabled) {
        background: #218838;
    }

    .btn-success:disabled {
        background: #6c757d;
        opacity: 0.65;
        cursor: not-allowed;
    }
</style>

@code {
    [Parameter]
    public string ProjectName { get; set; } = "";

    [Parameter]
    public string Environment { get; set; } = "Production";

    [Parameter]
    public BuildDto ProjectBuild { get; set; }

    [Parameter]
    public BuildDto ConfigBuild { get; set; }

    [Parameter]
    public List<WorkItemDto> Bugs { get; set; } = new();

    [Parameter]
    public List<WorkItemDto> PBIs { get; set; } = new();

    [Parameter]
    public string RequestedBy { get; set; } = "Admin User";

    [Parameter]
    public string ApprovedBy { get; set; } = "Release Management";

    private bool IsReadyForDownload => ProjectBuild != null && ConfigBuild != null;
    private string StatusMessage = "";
    private bool IsError = false;

    private async Task DownloadDocument()
    {
        try
        {
            StatusMessage = "Generating document...";
            IsError = false;

            var documentBytes = DocumentService.GenerateReleaseDocument(
                ProjectName,
                Environment,
                ProjectBuild,
                ConfigBuild,
                Bugs,
                PBIs,
                RequestedBy,
                ApprovedBy);

            var fileName = $"ReleaseNotes_{ProjectName}_{DateTime.Now:yyyyMMdd_HHmmss}.docx";

            // Convert bytes to base64 for download
            var base64String = Convert.ToBase64String(documentBytes);

            // Trigger browser download
            await JSRuntime.InvokeVoidAsync("downloadFile", base64String, fileName);

            StatusMessage = "Document downloaded successfully!";
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error generating document: {ex.Message}";
            IsError = true;
        }
    }
}