@using ReleaseNoteBuilder.Application.DTOs

<div class="workitem-subsection">
    <h5>📖 User Stories</h5>
    <div class="workitem-query">
        <textarea @bind="userStoriesQuery" 
                  class="form-control query-input" 
                  rows="2" 
                  placeholder="ADO query for user stories..."></textarea>
        <button @onclick="SearchUserStories" 
                class="btn btn-sm btn-info" 
                disabled="@isLoadingUserStories">
            @if (isLoadingUserStories)
            {
                <span>🔍 Searching...</span>
            }
            else
            {
                <span>🔍 Search User Stories</span>
            }
        </button>
    </div>

    @if (isLoadingUserStories)
    {
        <p class="loading">⏳ Loading user stories...</p>
    }
    else if (UserStoryItems.Any())
    {
        <div class="workitems-grid">
            @foreach (var item in UserStoryItems)
            {
                var isSelected = SelectedWorkItems.Any(x => x.Id == item.Id);
                <div class="work-item-card @(isSelected ? "selected" : "")" 
                     @onclick="() => ToggleWorkItem(item, !isSelected)">
                    <div class="work-item-header">
                        <input type="checkbox" checked="@isSelected" 
                               @onclick:stopPropagation 
                               @onchange="@((ChangeEventArgs e) => ToggleWorkItem(item, (bool)e.Value!))" />
                        <strong>@item.Title</strong>
                        <span class="badge badge-primary">@item.Type</span>
                    </div>
                    <p>@item.Description</p>
                    <small>ID: @item.AdoWorkItemId | Created: @item.CreatedDate.ToString("yyyy-MM-dd")</small>
                </div>
            }
        </div>
        <div class="selected-count">
            Selected: @UserStoryItems.Count(x => SelectedWorkItems.Any(y => y.Id == x.Id)) / @UserStoryItems.Count items
        </div>
    }
    else if (!isLoadingUserStories && !UserStoryItems.Any())
    {
        <p class="no-items">No user stories found.</p>
    }
</div>

@code {
    [Parameter]
    public List<WorkItemDto> UserStoryItems { get; set; } = new();

    [Parameter]
    public EventCallback<List<WorkItemDto>> UserStoryItemsChanged { get; set; }

    [Parameter]
    public List<WorkItemDto> SelectedWorkItems { get; set; } = new();

    [Parameter]
    public EventCallback<List<WorkItemDto>> SelectedWorkItemsChanged { get; set; }

    [Parameter]
    public string ErrorMessage { get; set; } = "";

    [Parameter]
    public EventCallback<string> ErrorMessageChanged { get; set; }

    [Parameter]
    public string Project { get; set; } = "";

    private string userStoriesQuery = "[System.WorkItemType] = 'User Story' AND [System.State] = 'Ready'";
    private bool isLoadingUserStories = false;

    private async Task SearchUserStories()
    {
        isLoadingUserStories = true;
        ErrorMessage = "";
        try
        {
            // TODO: Integrate with ADO service using userStoriesQuery
            // This should call: IAdoService.GetWorkItemsByQueryAsync(userStoriesQuery)

            UserStoryItems = new List<WorkItemDto>
            {
                new WorkItemDto 
                { 
                    Id = 3, 
                    AdoWorkItemId = "12346", 
                    Title = "Dashboard performance enhancement", 
                    Type = "User Story", 
                    Description = "Improve dashboard load time to under 2 seconds", 
                    CreatedDate = DateTime.Now.AddDays(-3)
                },
                new WorkItemDto 
                { 
                    Id = 4, 
                    AdoWorkItemId = "12348", 
                    Title = "Add export to PDF functionality", 
                    Type = "User Story", 
                    Description = "Users should be able to export reports to PDF", 
                    CreatedDate = DateTime.Now.AddDays(-2)
                }
            };
            await UserStoryItemsChanged.InvokeAsync(UserStoryItems);
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to fetch user stories: {ex.Message}";
            await ErrorMessageChanged.InvokeAsync(ErrorMessage);
        }
        finally
        {
            isLoadingUserStories = false;
        }
    }

    private async Task ToggleWorkItem(WorkItemDto item, bool isSelected)
    {
        if (isSelected && !SelectedWorkItems.Any(x => x.Id == item.Id))
        {
            SelectedWorkItems.Add(item);
        }
        else if (!isSelected)
        {
            SelectedWorkItems.RemoveAll(x => x.Id == item.Id);
        }
        await SelectedWorkItemsChanged.InvokeAsync(SelectedWorkItems);
    }
}