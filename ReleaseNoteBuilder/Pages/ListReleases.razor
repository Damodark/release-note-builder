@page "/releases"

@using Microsoft.JSInterop
@using ReleaseNoteBuilder.Application.Interfaces
@using ReleaseNoteBuilder.Application.DTOs
@inject IReleaseService ReleaseService
@inject IReleaseNoteGenerator NoteGenerator
@inject IJSRuntime JS
@inject NavigationManager Navigation

<div class="releases-header">
    <h3>Release History</h3>
    <button @onclick="CreateNewRelease" class="btn-create-release">
        Add New Release
    </button>
</div>

<style>
    .releases-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding-bottom: 15px;
        border-bottom: 2px solid #ddd;
    }

    .releases-header h3 {
        margin: 0;
        font-size: 24px;
        color: #333;
    }

    .btn-create-release {
        padding: 10px 20px;
        background: #107c10;
        color: white;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-weight: bold;
        font-size: 16px;
        transition: all 0.2s ease;
    }

    .btn-create-release:hover {
        background: #0d5c0d;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    }
</style>

<!-- SEARCH + FILTER -->
<button @onclick="ToggleFilters" class="filter-toggle">
    @(showFilters ? "Hide Filters" : "Show Filters")
</button>

@if (showFilters)
{
    <div class="filters">

        <div class="filter-item">
            <label>Search</label>
            <input @bind="searchText" @bind:event="oninput" />
        </div>

        <div class="filter-item">
            <label>Environment</label>
            <select @bind="filterEnv">
                <option value="">All</option>
                <option>DEV</option>
                <option>TEST</option>
                <option>UAT</option>
                <option>PROD</option>
            </select>
        </div>

        <div class="filter-item">
            <label>&nbsp;</label>
            <button @onclick="ExportToWord">📄 Export</button>
        </div>

    </div>
}
<br /><br />

@if (records == null)
{
    <p>Loading...</p>
}
else if (!records.Any())
{
    <p>No releases found.</p>
}
else
{
    <table>
        <thead>
        <tr>
            <th>Build</th>
            <th>Project</th>
            <th>Env</th>
            <th>Branch</th>
            <th>Date</th>
            <th>Actions</th>
        </tr>
        </thead>

        <tbody>
        @foreach (var r in Filtered())
        {
            <tr class="@GetRowClass(r.Environment ?? "")">
                <td>@r.BuildId</td>
                <td>@r.Project</td>

                <td>
                    <span class="badge @GetRowClass(r.Environment)">
                        @r.Environment
                    </span>
                </td>

                <td>@r.Branch</td>
                <td>@r.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>

                <td>
                    <button @onclick="(() => ShowDetails(r))">
                        <i class="fa-solid fa-eye"></i>
                    </button>

                    <button @onclick="(() => Edit(r))">
                        <i class="fa-solid fa-pen"></i>
                    </button>

                    <button @onclick="(() => Delete(r.Id))">
                        <i class="fa-solid fa-trash"></i>
                    </button>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

<div class="pagination-container">

    <!-- LEFT: INFO -->
    <div class="pagination-info">
        Showing @((currentPage - 1) * pageSize + 1)
        to @(Math.Min(currentPage * pageSize, TotalRecords()))
        of @TotalRecords() records
    </div>

    <!-- CENTER: PAGINATION -->
    <div class="pagination-controls">

        <button @onclick="PrevPage" disabled="@(currentPage == 1)">Prev</button>

        @for (int i = 1; i <= TotalPages(); i++)
        {
            var pageNumber = i;

            <button @onclick="() => GoToPage(pageNumber)"
                    disabled="@(pageNumber == currentPage)"
                    class="@(pageNumber == currentPage ? "active-page" : "")">
                @pageNumber
            </button>
        }

        <button @onclick="NextPage" disabled="@(currentPage >= TotalPages())">Next</button>

    </div>

    <!-- RIGHT: PAGE SIZE -->
    <div class="pagination-extra">
        <label>Rows per page:</label>
        <select @bind="pageSize">
            <option value="5">5</option>
            <option value="10">10</option>
            <option value="20">20</option>
        </select>
    </div>

</div>
<br />

<!-- ✅ MODAL -->
@if (selected != null)
{
    <div class="modal-overlay">
        <div class="modal-box">

            <h4>Edit Release</h4>

            <label>Project</label>
            <input @bind="selected.Project" />

            <label>Build</label>
            <input type="number" @bind="selected.BuildId" />

            <label>Environment</label>
            <select @bind="selected.Environment">
                <option>DEV</option>
                <option>TEST</option>
                <option>UAT</option>
                <option>PROD</option>
            </select>

            <label>Branch</label>
            <input @bind="selected.Branch" />

            <label>Notes</label>
            <textarea @bind="selected.Notes"></textarea>

            <br />

            <button @onclick="Save">Save</button>
            <button @onclick="CloseModal">Cancel</button>

        </div>
    </div>
}

@code {
    List<ReleaseDto> records;
    ReleaseDto selected;

    IEnumerable<ReleaseDto> FilteredData =>
        records.Where(r =>
            (string.IsNullOrEmpty(searchText) ||
             r.Project.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
             r.Branch.Contains(searchText, StringComparison.OrdinalIgnoreCase))
            &&
            (string.IsNullOrEmpty(filterEnv) || r.Environment == filterEnv)
        );

    string _searchText = "";
    string filterEnv = "";

    int currentPage = 1;

    int _pageSize = 5;
    int pageSize
    {
        get => _pageSize;
        set
        {
            if (_pageSize != value)
            {
                _pageSize = value;
                currentPage = 1;   // ✅ reset to page 1 when page size changes
                ValidatePage();
            }
        }
    }

    bool showFilters = true;

    void ToggleFilters()
    {
        showFilters = !showFilters;
    }



    string searchText
    {
        get => _searchText;
        set
        {
            if (_searchText != value)
            {
                _searchText = value;
                currentPage = 1;   // ✅ reset pagination here
                ValidatePage();
            }
        }
    }


    protected override async Task OnInitializedAsync()
    {
        records = await ReleaseService.GetAllReleasesAsync();
    }

    // ✅ FILTER + PAGING
    IEnumerable<ReleaseDto> Filtered()
    {
        var totalPages = (int)Math.Ceiling((double)FilteredData.Count() / pageSize);

        if (currentPage > totalPages)
        {
            currentPage = totalPages == 0 ? 1 : totalPages;
        }

        return FilteredData
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize);
    }

    int TotalRecords()
    {
        return FilteredData.Count();
    }


    int TotalPages()
        => (int)Math.Ceiling((double)TotalRecords() / pageSize);

    void NextPage()
    {
        if (currentPage < TotalPages())
            currentPage++;
    }

    void PrevPage()
    {
        if (currentPage > 1)
            currentPage--;
    }


    void GoToPage(int page)
    {
        if (page < 1 || page > TotalPages())
            return;

        currentPage = page;

      //  StateHasChanged();   // ✅ ensures UI updates
    }

    void ValidatePage()
    {
        if (currentPage > TotalPages())
            currentPage = TotalPages();
    }

    void ShowDetails(ReleaseDto r) => selected = new ReleaseDto
    {
        Id = r.Id,
        Project = r.Project,
        BuildId = r.BuildId,
        Environment = r.Environment,
        Branch = r.Branch,
        Notes = r.Notes
    };

    void Edit(ReleaseDto r) => ShowDetails(r);

    async Task Save()
    {
        var updateDto = new UpdateReleaseDto
        {
            Id = selected.Id,
            Project = selected.Project,
            BuildId = selected.BuildId,
            Environment = selected.Environment,
            Branch = selected.Branch,
            Notes = selected.Notes
        };

        await ReleaseService.UpdateReleaseAsync(updateDto);

        // Refresh the list
        records = await ReleaseService.GetAllReleasesAsync();

        await JS.InvokeVoidAsync("showToast", "Saved ✅");

        selected = null;
    }

    async Task Delete(int id)
    {
        var confirm = await JS.InvokeAsync<bool>("confirm", "Delete?");
        if (!confirm) return;

        await ReleaseService.DeleteReleaseAsync(id);

        // Refresh the list
        records = await ReleaseService.GetAllReleasesAsync();

        await JS.InvokeVoidAsync("showToast", "Deleted ✅");
    }

    void CloseModal() => selected = null;

    // ✅ EXPORT TO WORD
    async Task ExportToWord()
    {
        var content = await NoteGenerator.ExportToWordAsync(records);
        await JS.InvokeVoidAsync("downloadFile", "releases.doc", content);
    }

    string GetRowClass(string env) => env switch
    {
        "PROD" => "prod-row",
        "UAT" => "uat-row",
        "TEST" => "test-row",
        _ => ""
    };

    void CreateNewRelease()
    {
        // Navigation to the create release page
        Navigation.NavigateTo("releases/create");
    }
}